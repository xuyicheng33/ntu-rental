# Proxy for scraping (Clash, V2Ray, etc.)
SCRAPER_PROXY=http://127.0.0.1:7897

# Playwright browser settings
# SCRAPER_HEADLESS=false
# PLAYWRIGHT_CHROMIUM_EXECUTABLE=/path/to/chrome
# SCRAPER_USER_AGENT=Mozilla/5.0 ...

# PropertyGuru settings
# PROPERTYGURU_BROWSER=safari
# PROPERTYGURU_VERIFICATION_BROWSER=chrome
# PROPERTYGURU_MAX_PAGES_PER_SEARCH=5
# PROPERTYGURU_MANUAL_WAIT_MS=180000

# Static site mode (set automatically by build:static)
# NEXT_PUBLIC_STATIC_SITE=true
